    <!-- ===== Script linter ===== -->
    <string name="lint_local_outside_func">«local» outside a function — crashes in mksh/ash</string>
    <string name="lint_double_bracket">«[[ ]]» is a bashism — use «[ ]» (POSIX)</string>
    <string name="lint_array">Arrays are not supported in busybox ash</string>
    <string name="lint_function_keyword">«function name» keyword — use «name() {»</string>
    <string name="lint_declare">«declare/typeset» is not available in ash</string>
    <string name="lint_herestring">Herestring «&lt;&lt;&lt;» is a bashism — use «echo | cmd»</string>
    <string name="lint_process_subst">Process substitution «&lt;(…)» is a bashism</string>
    <string name="lint_replace_expansion">«${var/…}» replacement may not work in busybox ash</string>
    <string name="lint_unquoted_rm">«rm -rf» with an unquoted variable — quote it: \"$VAR\"</string>
    <string name="lint_write_block">Direct write to /dev/block — bootloop risk</string>
    <string name="lint_remount_system">rw-remount of a system partition breaks the systemless approach — use the module overlay</string>
    <string name="lint_chmod_777">chmod 777 — insecure permissions, prefer 0755/0644</string>
    <string name="lint_source_cmd">«source» — use «.» (POSIX)</string>
    <string name="lint_let_cmd">«let» — use «$(( ))» (POSIX)</string>
    <string name="lint_random">«$RANDOM» is not available in ash</string>

