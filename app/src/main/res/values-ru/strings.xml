    <!-- ===== Линтер скриптов ===== -->
    <string name="lint_local_outside_func">«local» вне функции — падение в mksh/ash</string>
    <string name="lint_double_bracket">«[[ ]]» — башизм, используйте «[ ]» (POSIX)</string>
    <string name="lint_array">Массивы не поддерживаются в busybox ash</string>
    <string name="lint_function_keyword">Ключевое слово «function» — используйте «имя() {»</string>
    <string name="lint_declare">«declare/typeset» недоступны в ash</string>
    <string name="lint_herestring">Herestring «&lt;&lt;&lt;» — башизм, используйте «echo | cmd»</string>
    <string name="lint_process_subst">Подстановка процесса «&lt;(…)» — башизм</string>
    <string name="lint_replace_expansion">Замена «${var/…}» может не работать в busybox ash</string>
    <string name="lint_unquoted_rm">«rm -rf» с переменной без кавычек — экранируйте: \"$VAR\"</string>
    <string name="lint_write_block">Прямая запись в /dev/block — риск бутлупа</string>
    <string name="lint_remount_system">rw-remount системного раздела ломает systemless-подход — используйте оверлей модуля</string>
    <string name="lint_chmod_777">chmod 777 — небезопасные права, лучше 0755/0644</string>
    <string name="lint_source_cmd">«source» — используйте «.» (POSIX)</string>
    <string name="lint_let_cmd">«let» — используйте «$(( ))» (POSIX)</string>
    <string name="lint_random">«$RANDOM» недоступен в ash</string>

